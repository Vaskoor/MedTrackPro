    await prisma.healthLog.createMany({
        data: [
            { patientId: patientId, date: new Date(now.getFullYear(), now.getMonth(), now.getDate() - 1), sleepHours: 7.5, activityMinutes: 45, waterIntake: 2000, steps: 8500, symptoms: 'None' },
